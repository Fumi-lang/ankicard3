{
  "name": "memory-flow",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^dexie$": "<rootDir>/src/__mocks__/dexie.ts"
    }
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.9",
    "canvas-confetti": "^1.9.3",
    "dexie": "^4.0.11",
    "expo": "~54.0.33",
    "expo-linking": "^55.0.13",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "i18next": "^23.16.8",
    "mammoth": "^1.8.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^4.10.38",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.1",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.1",
    "react-native-worklets-core": "^1.6.3",
    "uuid": "^11.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^30.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
